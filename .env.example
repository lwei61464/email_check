# ============================================================
# 邮箱 IMAP 配置
# ============================================================
IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USERNAME=your_email@example.com
IMAP_PASSWORD=your_imap_app_password

# ============================================================
# 通义千问（Qwen / DashScope）API 配置
# ============================================================
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-plus

# ============================================================
# 系统行为配置
# ============================================================
# 定时轮询间隔（秒），默认 300（5分钟）
POLL_INTERVAL_SECONDS=300

# IMAP 连接超时（秒），默认 30
IMAP_TIMEOUT=30

# Spam 分类置信度阈值，高于此值才移入隔离区
SPAM_CONFIDENCE_THRESHOLD=0.90

# 同一发件人被判定为 spam 累计达到此次数后，才自动加入黑名单（默认 3）
BLACKLIST_THRESHOLD=3

# 隔离区邮件保留天数（超时后自动清除）
QUARANTINE_RETENTION_DAYS=7

# 待审核区邮件保留天数（低置信 spam，超时后自动清除）
REVIEW_RETENTION_DAYS=14

# 重要发件人白名单（逗号分隔，支持完整地址或 @domain.com 格式，留空表示不配置）
# 示例：IMPORTANT_SENDERS=boss@company.com,@client-domain.com,cto@partner.org
IMPORTANT_SENDERS=

# ============================================================
# 数据存储配置
# ============================================================
DB_PATH=storage/email_sorter.db

# ============================================================
# 通知渠道配置（可选）
# ============================================================
# 支持：log（仅日志）/ webhook
NOTIFY_CHANNEL=log
NOTIFY_WEBHOOK_URL=
